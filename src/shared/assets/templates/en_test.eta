<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="ru">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Test</title>
</head>
<body style="margin: 0; padding: 0; background-color: #121212; font-family: Arial, sans-serif; color: #e0e0e0; line-height: 1.6;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #121212;">
    <tr>
      <td align="center" style="padding: 30px 0;">
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color: #1e1e1e; border: 1px solid #2d3748;">
          <!-- Header -->
          <tr>
            <td style="background:#0f172a; padding:20px 30px; text-align:center; border-bottom:1px solid #2d3748;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center">
                    <div style="display:inline-block; margin-bottom:10px;"><img src="<%= it.domainName %>/static/image/logo.4e96a33c.png" alt="Rastvor is an international exchange service."></div>
                    <div style="color:#a0aec0; font-size:14px;">International exchange service, online 24/7</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-size: 20px; font-weight: bold; color: #8aa459; text-align: center; font-family: Arial, sans-serif; padding: 25px 0 15px;">
                    Test
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; line-height: 1.6; padding-bottom: 15px;">
                    You have submitted a test field name: <%= it.name %>
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; line-height: 1.6; padding-bottom: 15px;">
                    <%= new Date().toString() %>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 20px 0;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #1e1e1e; border: 1px solid #2d3748;">
                      <tr>
                        <td align="center" style="padding: 15px;">
                          <table cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td align="center" style="background-color: #8aa459; padding: 15px 30px; font-weight: bold; font-size: 18px; font-family: Arial, sans-serif; color: #121212; text-decoration: none;">
                                <a href="#" style="color: #121212; text-decoration: none; display: block;">Test button</a>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="font-size: 20px; font-weight: bold; color: #8aa459; text-align: center; font-family: Arial, sans-serif; padding: 25px 0 15px;">
                    Do you have any questions?
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; line-height: 1.6; padding-bottom: 10px;">
                    Please contact our support team on our website or by email at
                    <a href="mailto:support@rastvor.cc" style="color: #8aa459; text-decoration: underline;">support@rastvor.cc</a>
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; line-height: 1.6;">
                    If this message was delivered to you accidentally, please delete it. If you wish to unsubscribe from emails or newsletters, click
                    <a href="<%= it.domainName %>/contacts" style="color: #8aa459; text-decoration: underline;">here.</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#121212; padding:20px 30px; text-align:center; border-top:1px solid #2d3748; color:#a0aec0; font-size:13px;">
              <table cellpadding="0" cellspacing="0" border="0" style="margin:15px auto; text-align:center;">
                <tr>
                  <td style="padding:0 10px;">
                    <a href="<%= it.domainName %>/privacyPolicy" style="color:#8aa459; text-decoration:none; font-size:13px;">Privacy Policy</a>
                  </td>
                  <td style="padding:0 10px;">
                    <a href="<%= it.domainName %>/rules" style="color:#8aa459; text-decoration:none; font-size:13px;">Exchange rules</a>
                  </td>
                  <td style="padding:0 10px;">
                    <a href="<%= it.domainName %>/contacts" style="color:#8aa459; text-decoration:none; font-size:13px;">Contacts</a>
                  </td>
                </tr>
              </table>
              <p style="margin:10px 0;">© 2025 Rastvor. All rights reserved.</p>
              <p style="font-size:11px; color:#718096; margin:10px 0;">This is an automated email. Please do not reply to it.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>