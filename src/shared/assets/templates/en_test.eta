<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="ru">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Test</title>
</head>
<body style="font-family:'Inter','Avenir',Helvetica,sans-serif;background-color:#f3f6fb;color:#2d3748;margin:0;padding:0;line-height:1.6">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F3F6FB;">
    <tr>
      <td align="center" style="padding:30px 0;">
        <table width="540" cellpadding="0" cellspacing="0" border="0" style="width:650px;margin:0 auto;background-color:#ffffff;border-radius:12px;padding:30px">
          <!-- Header -->
          <tr>
            <td style="padding:20px 30px; text-align:center; border-bottom:1px solid #a0aec0;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center">
                    <div style="display:inline-block; margin-bottom:10px;"><img src="<%= it.domainName %>/static/image/logo.4e96a33c.png" alt="AltSwap is an international exchange service."></div>
                    <div style="color:#a0aec0; font-size:14px;">International exchange service</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-size: 20px; font-weight: bold; text-align: center; font-family: Arial, sans-serif; padding: 25px 0 15px;">
                    Тест
                  </td>
                </tr>
                <tr>
                  <td style="line-height: 1.6; padding-bottom: 15px;">
                    You submitted a test field name: <%= it.name %>
                  </td>
                </tr>
                <tr>
                  <td style="line-height: 1.6; padding-bottom: 15px;">
                    <%= new Date().toString() %>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 20px 0;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f3f6fb; border-radius:8px; padding:20px; margin:20px 0; border:1px solid #f3f6fb;">
                      <tr>
                        <td align="center">
                          <table cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="display:block; width:100%; max-width:400px; margin:25px auto; background:#FFE044; color:#000; text-align:center; border-radius:6px; font-weight:bold; text-decoration:none; font-size:18px; padding:15px;">
                                <a href="<%= it.domainName %>/requests" style="color:#000; text-decoration:none; display:block; width:100%; height:100%;">Go to your personal account</a>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="font-size: 20px; font-weight: bold; text-align: center; padding: 25px 0 15px;">
                    Do you have any questions?
                  </td>
                </tr>
                <tr>
                  <td style="line-height: 1.6; padding-bottom: 10px;">
                    Please contact our support team on our website or by email
                    <a href="mailto:info@altswap.cc" style="color: #000; text-decoration: underline;">info@altswap.cc</a>
                  </td>
                </tr>
                <tr>
                  <td style="line-height: 1.6;">
                    If this message was delivered to you accidentally, please delete it. If you wish to unsubscribe from emails or newsletters, click
                    <a href="<%= it.domainName %>/contacts" style="color: #000; text-decoration: underline;">here.</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:20px 30px; text-align:center; border-top:1px solid #a0aec0; font-size:13px;">
              <table cellpadding="0" cellspacing="0" border="0" style="margin:15px auto; text-align:center;">
                <tr>
                  <td style="padding:0 10px;">
                    <a href="<%= it.domainName %>/privacyPolicy" style="color:#000; text-decoration:none; font-size:13px;">Privacy Policy</a>
                  </td>
                  <td style="padding:0 10px;">
                    <a href="<%= it.domainName %>/rules" style="color:#000; text-decoration:none; font-size:13px;">Exchange rules</a>
                  </td>
                  <td style="padding:0 10px;">
                    <a href="<%= it.domainName %>/contacts" style="color:#000; text-decoration:none; font-size:13px;">Contacts</a>
                  </td>
                </tr>
              </table>
              <p style="margin:10px 0;">AltSwap -Cryptocurrency exchange service.</p>
              <p style="font-size:11px; color:#718096; margin:10px 0;">This is an automated email. Please do not reply to it.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
