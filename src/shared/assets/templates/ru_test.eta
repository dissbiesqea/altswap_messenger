<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="ru">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Тест</title>
</head>
<body style="margin: 0; padding: 0; background-color: #121212; font-family: Arial, sans-serif; color: #e0e0e0; line-height: 1.6;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #121212;">
    <tr>
      <td align="center" style="padding: 30px 0;">
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color: #1e1e1e; border: 1px solid #2d3748;">
          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(to right, #0f172a, #1e293b); padding: 20px 30px; border-bottom: 1px solid #2d3748;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center">
                    <table cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-bottom: 10px;">
                          <div style="display:inline-block; margin-bottom:10px;"><img src="<%= it.domainName %>/static/image/logo.4e96a33c.png" alt="Rastvor - международный обменный сервис"></div>
                        </td>
                      </tr>
                    </table>
                    <table cellpadding="0" cellspacing="0" border="0" style="margin-top: 10px;">
                      <tr>
                        <td align="center" style="font-size: 14px; color: #a0aec0; font-family: Arial, sans-serif;">
                          Международный обменник, онлайн 24/7
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-size: 20px; font-weight: bold; color: #8aa459; text-align: center; font-family: Arial, sans-serif; padding: 25px 0 15px;">
                    Тест
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; line-height: 1.6; padding-bottom: 15px;">
                    Вы отправили тестовое поле name: <%= it.name %>
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; line-height: 1.6; padding-bottom: 15px;">
                    <%= new Date().toString() %>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 20px 0;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #1e1e1e; border: 1px solid #2d3748;">
                      <tr>
                        <td align="center" style="padding: 15px;">
                          <table cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td align="center" style="background-color: #8aa459; padding: 15px 30px; font-weight: bold; font-size: 18px; font-family: Arial, sans-serif; color: #121212; text-decoration: none;">
                                <a href="#" style="color: #121212; text-decoration: none; display: block;">Тестовая кнопка</a>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="font-size: 20px; font-weight: bold; color: #8aa459; text-align: center; font-family: Arial, sans-serif; padding: 25px 0 15px;">
                    У Вас остались вопросы?
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; line-height: 1.6; padding-bottom: 10px;">
                    Обратитесь в службу поддержки на нашем сайте или на почту 
                    <a href="mailto:support@rastvor.cc" style="color: #8aa459; text-decoration: underline;">support@rastvor.cc</a>
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; line-height: 1.6;">
                    Если это сообщение было доставлено Вам случайно, пожалуйста, удалите его. Если Вы хотите отписаться от писем или рассылок нажмите 
                    <a href="<%= it.domainName %>/contacts" style="color: #8aa459; text-decoration: underline;">здесь.</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #121212; padding: 20px 30px; border-top: 1px solid #2d3748;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center">
                    <table cellpadding="0" cellspacing="10" border="0">
                      <tr>
                        <td>
                          <a href="<%= it.domainName %>/privacyPolicy" style="color: #8aa459; text-decoration: none; font-size: 13px; font-family: Arial, sans-serif;">Политика конфиденциальности</a>
                        </td>
                        <td>
                          <a href="<%= it.domainName %>/rules" style="color: #8aa459; text-decoration: none; font-size: 13px; font-family: Arial, sans-serif;">Правила обмена</a>
                        </td>
                        <td>
                          <a href="<%= it.domainName %>/contacts" style="color: #8aa459; text-decoration: none; font-size: 13px; font-family: Arial, sans-serif;">Контакты</a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding: 15px 0 5px;">
                    <span style="color: #a0aec0; font-size: 13px; font-family: Arial, sans-serif;">© 2025 Rastvor. Все права защищены.</span>
                  </td>
                </tr>
                <tr>
                  <td align="center">
                    <span style="color: #718096; font-size: 11px; font-family: Arial, sans-serif;">Это автоматическое письмо. Пожалуйста, не отвечайте на него.</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>