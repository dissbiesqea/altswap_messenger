{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["DOM", "ESNext"],
		"module": "ESNext",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"moduleResolution": "bundler",
		"useDefineForClassFields": true,
		"baseUrl": ".",
		"plugins": [
			{
				"name": "@effect/language-service"
			}
		],
		"paths": {
			"*": ["./src/*"]
		}
	},
	"include": ["src"]
}
